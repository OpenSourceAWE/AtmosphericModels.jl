if [[ $(basename $(pwd)) == "bin" ]]; then
    cd ..
fi
export JULIA_PKG_SERVER_REGISTRY_PREFERANCE=eager

if [[ $# -gt 0 ]]; then
    JULIA_ARGS=("$@")
else
    JULIA_ARGS=(-i -e 'using KiteUtils: menu')
fi

LANG=en_US julia --project "${JULIA_ARGS[@]}"
